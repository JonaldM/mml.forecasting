<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Forecast Config: Form View                                    -->
    <!-- ============================================================ -->
    <record id="view_forecast_config_form" model="ir.ui.view">
        <field name="name">forecast.config.form</field>
        <field name="model">forecast.config</field>
        <field name="arch" type="xml">
            <form string="Financial Forecast">
                <header>
                    <button name="action_generate_forecast"
                            string="Generate Forecast"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'generated'"
                            confirm="This will delete all generated forecast data. Continue?"/>
                    <button name="action_lock"
                            string="Lock"
                            type="object"
                            invisible="state != 'generated'"/>
                    <button name="action_duplicate_scenario"
                            string="Duplicate as Scenario"
                            type="object"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,generated,locked"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. FY2026 Base Case"/></h1>
                    </div>
                    <group>
                        <group string="Period">
                            <field name="date_start"/>
                            <field name="horizon_months"/>
                            <field name="date_end"/>
                        </group>
                        <group string="Scenario">
                            <field name="scenario"/>
                            <field name="volume_adjustment_pct"
                                   widget="percentage"/>
                            <field name="freight_rate_cbm"/>
                            <field name="tax_id"/>
                        </group>
                    </group>

                    <!-- Summary KPIs (visible when generated) -->
                    <group string="Forecast Summary"
                           name="forecast_summary"
                           invisible="state == 'draft'">
                        <group>
                            <field name="total_revenue" widget="monetary"/>
                            <field name="total_cogs" widget="monetary"/>
                        </group>
                        <group>
                            <field name="total_gross_margin" widget="monetary"/>
                            <field name="gross_margin_pct"
                                   widget="percentage"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab: FX Rates -->
                        <page string="FX Rates" name="fx_rates">
                            <field name="fx_rate_ids">
                                <list editable="bottom">
                                    <field name="currency_id"/>
                                    <field name="rate_to_nzd"/>
                                    <field name="nzd_per_unit"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Customer Payment Terms -->
                        <page string="Customer Payment Terms" name="customer_terms">
                            <field name="customer_term_ids">
                                <list editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="rule_type"/>
                                    <field name="buffer_days"/>
                                    <field name="pay_day_of_month"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Supplier Payment Terms -->
                        <page string="Supplier Payment Terms" name="supplier_terms">
                            <field name="supplier_term_ids">
                                <list editable="bottom">
                                    <field name="supplier_id"/>
                                    <field name="deposit_pct"/>
                                    <field name="deposit_trigger_days"/>
                                    <field name="production_lead_days"/>
                                    <field name="origin_port_id"/>
                                    <field name="payment_method"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Notes -->
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Forecast Config: List View                                    -->
    <!-- ============================================================ -->
    <record id="view_forecast_config_list" model="ir.ui.view">
        <field name="name">forecast.config.list</field>
        <field name="model">forecast.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="scenario"
                       decoration-info="scenario == 'base'"
                       decoration-success="scenario == 'optimistic'"
                       decoration-danger="scenario == 'pessimistic'"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="total_revenue"/>
                <field name="gross_margin_pct" widget="percentage"/>
                <field name="state"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'generated'"
                       decoration-muted="state == 'locked'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Action                                                        -->
    <!-- ============================================================ -->
    <record id="action_forecast_config" model="ir.actions.act_window">
        <field name="name">Financial Forecasts</field>
        <field name="res_model">forecast.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first financial forecast
            </p>
            <p>
                Build driver-based P&amp;L, cash flow, and scenario forecasts
                powered by your ROQ demand signals.
            </p>
        </field>
    </record>

</odoo>
