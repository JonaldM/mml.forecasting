<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_forecast_opex_list" model="ir.ui.view">
        <field name="name">forecast.opex.line.list</field>
        <field name="model">forecast.opex.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="config_id"/>
                <field name="name"/>
                <field name="cost_type"/>
                <field name="monthly_amount"/>
                <field name="pct_of_revenue"/>
                <field name="brand"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

</odoo>
