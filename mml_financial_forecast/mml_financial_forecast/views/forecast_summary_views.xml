<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- P&L Pivot View                                                -->
    <!-- ============================================================ -->
    <record id="view_forecast_pnl_pivot" model="ir.ui.view">
        <field name="name">forecast.pnl.line.pivot</field>
        <field name="model">forecast.pnl.line</field>
        <field name="arch" type="xml">
            <pivot string="P&amp;L Forecast">
                <field name="period_label" type="row"/>
                <field name="revenue" type="measure"/>
                <field name="total_cogs" type="measure"/>
                <field name="gross_margin" type="measure"/>
                <field name="total_opex" type="measure"/>
                <field name="ebitda" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_forecast_pnl_graph" model="ir.ui.view">
        <field name="name">forecast.pnl.line.graph</field>
        <field name="model">forecast.pnl.line</field>
        <field name="arch" type="xml">
            <graph string="P&amp;L Forecast" type="bar">
                <field name="period_label"/>
                <field name="revenue" type="measure"/>
                <field name="gross_margin" type="measure"/>
                <field name="ebitda" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_forecast_pnl" model="ir.actions.act_window">
        <field name="name">P&amp;L Forecast</field>
        <field name="res_model">forecast.pnl.line</field>
        <field name="view_mode">list,pivot,graph</field>
    </record>

    <!-- ============================================================ -->
    <!-- Cash Flow Pivot View                                          -->
    <!-- ============================================================ -->
    <record id="view_forecast_cashflow_graph" model="ir.ui.view">
        <field name="name">forecast.cashflow.line.graph</field>
        <field name="model">forecast.cashflow.line</field>
        <field name="arch" type="xml">
            <graph string="Cash Flow Forecast" type="line">
                <field name="period_label"/>
                <field name="net_cashflow" type="measure"/>
                <field name="cumulative_cashflow" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_forecast_cashflow" model="ir.actions.act_window">
        <field name="name">Cash Flow Forecast</field>
        <field name="res_model">forecast.cashflow.line</field>
        <field name="view_mode">list,graph</field>
    </record>

    <!-- ============================================================ -->
    <!-- Revenue Detail with Pivot                                     -->
    <!-- ============================================================ -->
    <record id="view_forecast_revenue_pivot" model="ir.ui.view">
        <field name="name">forecast.revenue.line.pivot</field>
        <field name="model">forecast.revenue.line</field>
        <field name="arch" type="xml">
            <pivot string="Revenue Forecast">
                <field name="period_label" type="row"/>
                <field name="brand" type="col"/>
                <field name="revenue" type="measure"/>
                <field name="forecast_units" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_forecast_revenue" model="ir.actions.act_window">
        <field name="name">Revenue Detail</field>
        <field name="res_model">forecast.revenue.line</field>
        <field name="view_mode">list,pivot,graph</field>
    </record>

    <!-- ============================================================ -->
    <!-- COGS Detail with Pivot                                        -->
    <!-- ============================================================ -->
    <record id="view_forecast_cogs_pivot" model="ir.ui.view">
        <field name="name">forecast.cogs.line.pivot</field>
        <field name="model">forecast.cogs.line</field>
        <field name="arch" type="xml">
            <pivot string="COGS Forecast">
                <field name="period_label" type="row"/>
                <field name="brand" type="col"/>
                <field name="fob_total_nzd" type="measure"/>
                <field name="freight_total_nzd" type="measure"/>
                <field name="duty_total_nzd" type="measure"/>
                <field name="tpl_total_nzd" type="measure"/>
                <field name="total_cogs_nzd" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_forecast_cogs" model="ir.actions.act_window">
        <field name="name">COGS Detail</field>
        <field name="res_model">forecast.cogs.line</field>
        <field name="view_mode">list,pivot</field>
    </record>

</odoo>
