<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Forecast Config: Form View                                    -->
    <!-- ============================================================ -->
    <record id="view_forecast_config_form" model="ir.ui.view">
        <field name="name">forecast.config.form</field>
        <field name="model">forecast.config</field>
        <field name="arch" type="xml">
            <form string="Financial Forecast">
                <header>
                    <button name="action_generate_forecast"
                            string="Generate Forecast"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'generated'"
                            confirm="This will delete all generated forecast data. Continue?"/>
                    <button name="action_lock"
                            string="Lock"
                            type="object"
                            invisible="state != 'generated'"/>
                    <button name="action_duplicate_scenario"
                            string="Duplicate as Scenario"
                            type="object"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,generated,locked"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. FY2026 Base Case"/></h1>
                    </div>
                    <group>
                        <group string="Period">
                            <field name="date_start"/>
                            <field name="horizon_months"/>
                            <field name="date_end"/>
                        </group>
                        <group string="Scenario">
                            <field name="scenario"/>
                            <field name="volume_adjustment_pct"
                                   widget="percentage"/>
                            <field name="freight_rate_cbm"/>
                        </group>
                    </group>

                    <!-- Summary KPIs (visible when generated) -->
                    <group string="Forecast Summary"
                           invisible="state == 'draft'">
                        <group>
                            <field name="total_revenue" widget="monetary"/>
                            <field name="total_cogs" widget="monetary"/>
                        </group>
                        <group>
                            <field name="total_gross_margin" widget="monetary"/>
                            <field name="gross_margin_pct"
                                   widget="percentage"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab: FX Rates -->
                        <page string="FX Rates" name="fx_rates">
                            <field name="fx_rate_ids">
                                <list editable="bottom">
                                    <field name="currency_id"/>
                                    <field name="rate_to_nzd"/>
                                    <field name="nzd_per_unit"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Customer Payment Terms -->
                        <page string="Customer Payment Terms" name="customer_terms">
                            <field name="customer_term_ids">
                                <list editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="rule_type"/>
                                    <field name="buffer_days"/>
                                    <field name="pay_day_of_month"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Operating Expenses -->
                        <page string="Operating Expenses" name="opex">
                            <field name="opex_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="cost_type"/>
                                    <field name="monthly_amount"
                                           invisible="cost_type != 'fixed'"/>
                                    <field name="pct_of_revenue"
                                           invisible="cost_type != 'variable'"/>
                                    <field name="brand"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: P&L Summary (generated) -->
                        <page string="P&amp;L Summary" name="pnl"
                              invisible="state == 'draft'">
                            <field name="pnl_line_ids" readonly="1">
                                <list decoration-bf="True">
                                    <field name="period_label"/>
                                    <field name="revenue" sum="Total"/>
                                    <field name="cogs_fob" sum="Total"/>
                                    <field name="cogs_freight" sum="Total"/>
                                    <field name="cogs_duty" sum="Total"/>
                                    <field name="cogs_3pl" sum="Total"/>
                                    <field name="total_cogs" sum="Total"/>
                                    <field name="gross_margin" sum="Total"/>
                                    <field name="gross_margin_pct"
                                           widget="percentage"/>
                                    <field name="opex_fixed" sum="Total"/>
                                    <field name="opex_variable" sum="Total"/>
                                    <field name="total_opex" sum="Total"/>
                                    <field name="ebitda" sum="Total"/>
                                    <field name="ebitda_pct"
                                           widget="percentage"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Cash Flow (generated) -->
                        <page string="Cash Flow" name="cashflow"
                              invisible="state == 'draft'">
                            <field name="cashflow_line_ids" readonly="1">
                                <list>
                                    <field name="period_label"/>
                                    <field name="receipts_from_customers"
                                           sum="Total"/>
                                    <field name="payments_fob" sum="Total"/>
                                    <field name="payments_freight" sum="Total"/>
                                    <field name="payments_duty_gst"
                                           sum="Total"/>
                                    <field name="payments_3pl" sum="Total"/>
                                    <field name="payments_opex" sum="Total"/>
                                    <field name="total_outflows" sum="Total"/>
                                    <field name="net_cashflow" sum="Total"/>
                                    <field name="cumulative_cashflow"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Revenue Detail (generated) -->
                        <page string="Revenue Detail" name="revenue_detail"
                              invisible="state == 'draft'">
                            <field name="revenue_line_ids" readonly="1">
                                <list>
                                    <field name="period_label"/>
                                    <field name="brand"
                                           optional="show"/>
                                    <field name="partner_id"/>
                                    <field name="product_id"/>
                                    <field name="forecast_units"/>
                                    <field name="sell_price_unit"/>
                                    <field name="revenue" sum="Total"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: COGS Detail (generated) -->
                        <page string="COGS Detail" name="cogs_detail"
                              invisible="state == 'draft'">
                            <field name="cogs_line_ids" readonly="1">
                                <list>
                                    <field name="period_label"/>
                                    <field name="brand"
                                           optional="show"/>
                                    <field name="product_id"/>
                                    <field name="forecast_units"/>
                                    <field name="fob_unit_fcy"/>
                                    <field name="fob_currency"/>
                                    <field name="fx_rate_applied"/>
                                    <field name="fob_total_nzd" sum="Total"/>
                                    <field name="freight_total_nzd"
                                           sum="Total"/>
                                    <field name="duty_total_nzd" sum="Total"/>
                                    <field name="tpl_total_nzd" sum="Total"/>
                                    <field name="total_cogs_nzd" sum="Total"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Notes -->
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Forecast Config: List View                                    -->
    <!-- ============================================================ -->
    <record id="view_forecast_config_list" model="ir.ui.view">
        <field name="name">forecast.config.list</field>
        <field name="model">forecast.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="scenario"
                       decoration-info="scenario == 'base'"
                       decoration-success="scenario == 'optimistic'"
                       decoration-danger="scenario == 'pessimistic'"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="total_revenue"/>
                <field name="gross_margin_pct" widget="percentage"/>
                <field name="state"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'generated'"
                       decoration-muted="state == 'locked'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Action                                                        -->
    <!-- ============================================================ -->
    <record id="action_forecast_config" model="ir.actions.act_window">
        <field name="name">Financial Forecasts</field>
        <field name="res_model">forecast.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first financial forecast
            </p>
            <p>
                Build driver-based P&amp;L, cash flow, and scenario forecasts
                powered by your ROQ demand signals.
            </p>
        </field>
    </record>

</odoo>
